# CONFIGURAÇÕES DO SERVIDOR
PORT=4001
NODE_ENV=development

# OBRIGATÓRIO — O servidor não inicia sem estas chaves (process.exit(1))
# Gere um secret forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=gere_um_secret_forte_aqui_com_64_bytes_hexadecimais

# BANCO DE DADOS (PostgreSQL — Supabase, Neon ou AWS RDS)
DATABASE_URL="postgresql://user:password@host:5432/prazzo?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/prazzo?schema=public"

# IA (GOOGLE GEMINI)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui

# MONITORAMENTO PROCESSUAL (DATAJUD — CNJ)
# Chave pública padrão do CNJ (pode ser alterada): c3071221793c06ef97a05a02cd8af344
DATAJUD_API_KEY=c3071221793c06ef97a05a02cd8af344

# WEBHOOK DE PROCESSOS (Escavador/Jusbrasil)
# Secret compartilhado com a API de processos para validar assinatura HMAC-SHA256.
# OBRIGATÓRIO para o endpoint /api/webhooks/escavador funcionar.
ESCAVADOR_WEBHOOK_SECRET=seu_webhook_secret_aqui

# PAGAMENTOS (STRIPE)
# OBRIGATÓRIO — O servidor não inicia sem estas chaves
# Obtenha em: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_sua_chave_aqui
STRIPE_WEBHOOK_SECRET=whsec_sua_chave_aqui
STRIPE_PRICE_MONTHLY=price_seu_price_id_mensal
STRIPE_PRICE_ANNUAL=price_seu_price_id_anual

# GOOGLE CALENDAR (OAuth 2.0)
# Configure em: https://console.cloud.google.com/apis/credentials
# Redirect URI deve ser: https://seu-dominio.com/api/auth/google/callback
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4001/api/auth/google/callback

# REDIS (BullMQ — para fila de processamento de webhooks)
# Local: redis://127.0.0.1:6379 | Upstash: rediss://...
REDIS_URL=redis://127.0.0.1:6379

# URL DO FRONTEND MOBILE (para redirects OAuth e CORS)
FRONTEND_URL=exp://localhost:8081
