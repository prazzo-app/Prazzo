generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS — Tipagem forte para evitar valores inválidos no banco.
// Razão: String livres permitem valores como 'GOLD', 'HEARING', 'AUTO_AI'
// coexistindo com 'PREMIUM', 'AUDIENCE', 'VOICE' — quebrando filtros e a UI.
// ============================================================

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum EventType {
  AUDIENCE // Audiência judicial
  MEETING // Reunião geral
  FOCUS_BLOCK // Bloco de foco (RF05): tempo dedicado à produção de peças
  DEADLINE // Prazo calculado pelo motor de prazos (RF07)
  HEARING // Audiência de instrução (específico)
}

enum CreationSource {
  MANUAL // Criado pelo usuário na UI
  VOICE // Criado via microfone + Gemini (RF02)
  IMAGE_OCR // Criado via foto de documento + Gemini Vision (RF04)
  WEBHOOK_AUTO // Criado automaticamente a partir de movimentação processual (RF06)
  AUTO_AI // Criado pelo motor de prazos (RF07)
  GOOGLE_SYNC // Importado do Google Calendar
}

enum CaseStatus {
  ACTIVE // Monitoramento ativo
  ARCHIVED // Encerrado pelo usuário mas mantido no histórico
  CLOSED // Processo baixado/arquivado no tribunal
}

enum DeadlineStatus {
  PENDING // Aguardando ação do advogado
  FULFILLED // Prazo cumprido (usuário registrou ação)
  MISSED // Prazo perdido — alerta crítico (RF08)
}

enum NotificationChannel {
  PUSH // Firebase/OneSignal (Plano Free e Premium — RF09)
  EMAIL // Resend/SendGrid (Plano Premium — RF09)
  WHATSAPP // Meta Cloud API (Plano Premium — RF09, RF10)
}

// ============================================================
// MODELOS
// ============================================================

model User {
  id               String           @id @default(uuid())
  name             String
  email            String           @unique
  phone            String? // Para envio de WhatsApp (RF09/RF10). Opcional pois OAuth Google não fornece.
  password_hash    String? // Nullable: usuários que entram via OAuth Google não têm senha local.
  subscriptionTier SubscriptionTier @default(FREE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Dados profissionais (obrigatórios para advogados — regra de negócio do Prazzo)
  oabNumber String?
  oabState  String?

  // Consentimentos LGPD: timestamps registram o momento exato do aceite (requisito legal)
  acceptedTermsAt         DateTime?
  privacyPolicyAcceptedAt DateTime?

  // Integração Google Calendar (RF05 — sync bidirecional)
  // SEGURANÇA FUTURA: estes tokens devem ser criptografados em repouso (AES-256).
  // Por ora são armazenados como plaintext — item P1 no backlog de segurança.
  googleAccessToken  String?
  googleRefreshToken String?
  googleSyncToken    String?
  googleCalendarId   String?

  // Relações
  cases         Case[]
  events        Event[]
  notifications Notification[]
  auditLogs     AuditLog[]

  @@unique([oabNumber, oabState])
}

model Case {
  id          String     @id @default(uuid())
  userId      String
  caseNumber  String
  courtSystem String?
  status      CaseStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())

  // onDelete: Cascade — ao excluir um User, todos os seus processos são deletados.
  // Razão: Dados de processo sem dono são inúteis e violam LGPD (dados órfãos de titular deletado).
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  movements CaseMovement[]
  events    Event[]

  // Constraint: um usuário não pode cadastrar o mesmo número de processo duas vezes.
  // Previne duplicatas silenciosas que poluiriam o monitoramento e gerariam notificações duplas.
  @@unique([userId, caseNumber])
  // Índice para a query mais comum: listar processos de um usuário ordenados por data.
  @@index([userId])
}

model CaseMovement {
  id             String   @id @default(uuid())
  caseId         String
  date           DateTime
  rawPayload     String? // Payload bruto do webhook (JSON serializado) — mantido para auditoria e reprocessamento
  shortSummaryAi String? // Resumo gerado pelo Gemini em linguagem leiga (RF10)
  movementType   String? // Classificação da movimentação (futuro: enum)

  // onDelete: Cascade — movimentações pertencem ao processo; se o processo for deletado, elas vão junto.
  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model Event {
  id             String         @id @default(uuid())
  userId         String
  title          String
  description    String?
  startTime      DateTime
  endTime        DateTime
  relatedCaseId  String? // Nullable: evento pode ser avulso (sem processo vinculado)
  eventType      EventType      @default(MEETING)
  creationSource CreationSource @default(MANUAL)
  googleEventId  String? // ID no Google Calendar (para sync bidirecional — RF05)

  // onDelete: SetNull — se o processo for deletado, o evento sobrevive como avulso.
  // Razão: Um compromisso de audiência ainda é relevante para o advogado mesmo se o processo
  // for removido do monitoramento. Perder o evento seria perda de dados do advogado.
  relatedCase Case? @relation(fields: [relatedCaseId], references: [id], onDelete: SetNull)

  // onDelete: Cascade — evento sem dono não tem propósito (LGPD).
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  deadlines Deadline[]

  // Índice composto: a query de agenda sempre filtra por userId + ordenação por startTime.
  @@index([userId, startTime])
}

model Deadline {
  id                String         @id @default(uuid())
  eventId           String
  calculatedDueDate DateTime
  status            DeadlineStatus @default(PENDING)

  // onDelete: Cascade — prazo sem evento associado é incoerente e perigoso (mostraria deadlines fantasma).
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Índice para o Cron Job de inércia (RF08): busca diária de prazos PENDING próximos do vencimento.
  @@index([status, calculatedDueDate])
}

model Notification {
  id            String              @id @default(uuid())
  userId        String
  triggerSource String
  channel       NotificationChannel @default(PUSH)
  sentStatus    String              @default("PENDING")
  createdAt     DateTime            @default(now())

  // onDelete: Cascade — logs de notificação pertencem ao usuário (LGPD).
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Índice para queries de histórico de notificações por usuário (profile screen).
  @@index([userId, createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String? // Pode ser null para tentativas de login falhas
  action    String // EX: "LOGIN", "UPDATE_DEADLINE", "DELETE_CASE"
  resource  String? // EX: "CASE:uuid", "EVENT:uuid"
  payload   String? // JSON stringificando o que mudou ou os parâmetros da ação
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
